# API Key de Google AI Studio
# Obten tu key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo de Gemini a usar
GEMINI_MODEL=gemini-2.5-flash

# URL de tu proyecto Supabase
# Encuentrala en: Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=

# Anon Key de Supabase
# Encuentrala en: Settings > API Keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Token del bot de Discord
# Obten uno nuevo en Discord Developer Portal > Applications > Bot > Reset Token
DISCORD_BOT_TOKEN=

# Webhook de n8n para notificaciones/correo desde Discord
# En pruebas usa /webhook-test/... con Listen for test event activo
# En produccion usa /webhook/... con el workflow activo
N8N_WEBHOOK_URL=
