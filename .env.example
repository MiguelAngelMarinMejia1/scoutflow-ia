# API Key de Google AI Studio
# Obtén tu key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo de Gemini a usar
GEMINI_MODEL=gemini-2.5-flash

# URL de tu proyecto Supabase
# Encuéntrala en: Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=

# Anon Key de Supabase (Legacy)
# Encuéntrala en: Settings > API Keys > Legacy anon, service_role API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL del webhook de n8n para notificaciones
# Obtén la Production URL desde tu workflow en n8n
N8N_WEBHOOK_URL=